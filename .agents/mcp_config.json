{
  "mcpServers": {
    "composio": {
      "command": "bunx",
      "args": ["-y", "composio-core", "mcp"],
      "env": {
        "COMPOSIO_API_KEY": "${COMPOSIO_API_KEY}"
      }
    },
    "n8n-api": {
      "command": "bunx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "N8N_HOST": "${N8N_HOST}",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    }
  }
}
