{
  "mcpServers": {
    "codebase-memory": {
      "command": "codebase-memory-mcp",
      "args": ["--ui=true", "--port=9749"]
    },
    "composio": {
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest", "start"],
      "env": {
        "COMPOSIO_API_KEY": "ak_wxKeosFsuiZaLinpU7zG"
      }
    },
    "n8n-api": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "N8N_HOST": "http://localhost:5678",
        "N8N_API_KEY": "placeholder"
      }
    }
  }
}
